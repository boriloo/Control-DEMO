{
  "scripts": {
    "docker:up": "docker-compose up -d",
    "db:setup": "npx prisma migrate dev --schema ./server/prisma/schema.prisma --env-file .env",
    "dev:server": "cd server && npm run server",
    "dev:client": "cd client && npm run dev",

    "start:all": "npm run docker:up && npm run db:setup && concurrently \"npm run dev:server\" \"npm run dev:client\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}