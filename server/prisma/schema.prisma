datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

enum FileType {
  folder
  link

  @@map("filetype")
} 

model User {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @db.VarChar(100)
  email       String       @unique @db.VarChar(255)
  password    String       @db.VarChar(255)
  profileImage Bytes?   @map("profile_image")
  createdAt   DateTime     @default(now()) @map("created_at")
  desktops Desktop[]
  files    File[]

  @@map("users")
}

model Desktop {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(100)
  ownerId         String   @map("owner_id") @db.Uuid
  backgroundImage Bytes @map("background_image")
  createdAt       DateTime @default(now()) @map("created_at")

  owner User   @relation(fields: [ownerId], references: [id])
  files File[]

  @@map("desktops")
}

model File {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  ownerId   String   @map("owner_id") @db.Uuid
  desktopId String   @map("desktop_id") @db.Uuid
  parentId  String   @default("root") @map("parent_id") @db.VarChar(36)
  fileType  FileType @map("file_type")
  xPos      Int      @map("xpos")
  yPos      Int      @map("ypos")
  url       String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  owner   User    @relation(fields: [ownerId], references: [id])
  desktop Desktop @relation(fields: [desktopId], references: [id])

  @@map("files")
}